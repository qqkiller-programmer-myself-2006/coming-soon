# Resend API — สมัครฟรีที่ https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email ที่ใช้ส่ง (ต้อง verify domain ก่อน หรือใช้ onboarding@resend.dev ระหว่างทดสอบ)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email ที่รับแจ้งเตือนเมื่อมีคนสมัคร
NOTIFY_EMAIL=your@email.com
